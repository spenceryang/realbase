# Agent Wallet Private Key (Base Mainnet)
AGENT_PRIVATE_KEY=

# Coinbase Developer Platform (optional, get from portal.cdp.coinbase.com)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_ID=

# Base Builder Code (register at base.dev)
BUILDER_CODE=realbase

# Data Source API Keys
GREATSCHOOLS_API_KEY=
WALKSCORE_API_KEY=
CENSUS_API_KEY=
SOCRATA_APP_TOKEN=
RENTCAST_API_KEY=

# IPFS (Pinata)
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Contract Addresses (filled after deployment)
ORACLE_CONTRACT_ADDRESS=
REPORT_CONTRACT_ADDRESS=

# Agent Configuration
AGENT_TICK_INTERVAL_MS=900000
MIN_OPERATING_BALANCE_USDC=5
MIN_GAS_RESERVE_ETH=0.001
PORT=4021

# Base Mainnet RPC
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453

# Dashboard
NEXT_PUBLIC_AGENT_API_URL=http://localhost:4021
NEXT_PUBLIC_MAPBOX_TOKEN=
